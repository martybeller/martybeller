              "children": [
                {
                  "type": "text",
                  "id": "74uza",
                  "name": "\"Marty showed our students that a career in music can take  many shapesand inspired them to pursue their own creative vision.\"",
                  "fill": "#ffffffff",
                  "textGrowth": "fixed-width",
