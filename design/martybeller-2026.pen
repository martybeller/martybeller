          "children": [
            {
              "type": "frame",
              "id": "W8T9Q",
              "name": "Details",
              "width": 1344,
              "stroke": {
                "align": "inside",
                "thickness": 1
              },
              "gap": 48,
              "justifyContent": "center",
              "children": [
                {
                  "type": "frame",
                  "id": "OtORf",
                  "name": "Frame 1",
                  "width": "fill_container",
                  "height": "fill_container",
                  "stroke": {
                    "align": "inside",
                    "thickness": 1
                  },
                  "layout": "vertical",
                  "gap": 48,
                  "justifyContent": "space_between",
                  "children": [
                    {
                      "type": "text",
                      "id": "0tRql",
                      "name": "Twists, Turns and Breakthroughs: Inside the Work of Recording, Touring & Composing",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": 632,
                      "content": "Twists, Turns and Breakthroughs: Inside the Work of a Recording, Touring & Composing Career",
                      "lineHeight": 1.1666666666666667,
                      "fontFamily": "Inter Tight",
                      "fontSize": 45,
                      "fontWeight": "500"
                    },
                    {
                      "type": "text",
                      "id": "gFZuy",
                      "name": "Marty Beller, Grammy Award–winning composer and longtime drummer for the iconic alt-rock band They Might Be Giants, brings students inside the real world of a professional musician whose career moves seamlessly between recording, touring, and scoring for the screen—on stage, in the studio, and in the creative spaces where projects come to life.",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Marty Beller, Grammy Award–winning composer and longtime drummer for the iconic alt-rock band They Might Be Giants, brings students inside the real world of a professional musician whose career moves seamlessly between recording, touring, and scoring for the screen—on stage, in the studio, and in the creative spaces where projects come to life.",
                      "lineHeight": 1.25,
                      "fontFamily": "Inter Tight",
                      "fontSize": 32,
                      "fontWeight": "normal"
                    }
                  ]
                },
                {
                  "type": "frame",
                  "id": "2GcY5",
                  "name": "Frame 1",
                  "stroke": {
                    "align": "inside",
                    "thickness": 1
                  },
                  "layout": "vertical",
                  "gap": 40,
                  "children": [
                    {
                      "type": "text",
                      "id": "062cL",
                      "name": "This 90–120 minute interactive lecture is designed for university music students and is ideal for lecture series, visiting artist programs, and music school forums.",
                      "fill": "#ccccccff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "This 90–120 minute interactive lecture is designed for university music students and is ideal for lecture series, visiting artist programs, and music school forums.",
                      "lineHeight": 1.25,
                      "fontFamily": "Inter Tight",
                      "fontSize": 32,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "yKUc1",
                      "name": "Drawing on decades of experience drumming with They Might Be Giants and scoring for Film/TV, Marty brings students into the recording studio, onto the stage, and into vibrant creative meetings, immersing them in a whirlwind of twists, turns, and breakthroughs. Do you want this all-consuming, exhilarating lifestyle more than anything else in the world?! Yes, you do!",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Drawing on decades of experience drumming with They Might Be Giants and scoring for Film/TV, Marty brings students into the recording studio, onto the stage, and into vibrant creative meetings, immersing them in a whirlwind of twists, turns, and breakthroughs. Do you want this all-consuming, exhilarating lifestyle more than anything else in the world?! Yes, you do! ",
                      "lineHeight": 1.3333333333333333,
                      "fontFamily": "Inter Tight",
                      "fontSize": 24,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "eC3kV",
                      "name": "Students will leave this lecture with a roadmap for turning their passion for music into a lasting career. They will have learned about real workflow, taking direction, digesting feedback, and making creative decisions, whether recording, touring, or scoring. Most importantly, students will be inspired to develop their own unique voice as musicians and collaborators.",
                      "fill": "#ffffffff",
                      "textGrowth": "fixed-width",
                      "width": 664,
                      "content": "Students leave with a clear understanding of what a working music career looks like — and a real picture of what comes next. They will have learned about real workflow, taking direction, digesting feedback, and making creative decisions, whether recording, touring, or scoring. Most importantly, students will be inspired to develop their own unique voice as musicians and collaborators.",
                      "lineHeight": 1.3333333333333333,
                      "fontFamily": "Inter Tight",
                      "fontSize": 24,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
          ]
        },
