                                },
                                {
                                  "type": "text",
                                  "id": "ToCJa",
                                  "name": "Put Your Personality Into Your Music",
                                  "fill": "#ffffffff",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Put Your Personality Into Your Music",
                                  "lineHeight": 0.8333333333333334,
                                  "fontFamily": "Manrope",
                                  "fontSize": 24,
                                  "fontWeight": "700"
                                },
                                {
                                  "type": "text",
                                  "id": "b9cBR",
