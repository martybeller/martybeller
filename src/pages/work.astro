---
import Layout from '../layouts/Layout.astro';
import WorkModal from '../components/WorkModal.astro';
import VideoModal from '../components/VideoModal.astro';

interface Track {
	title: string;
	url: string;
}

interface ComposerCard {
	id: string;
	title: string;
	image: string;
	owner: string;
	tracks: Track[];
}

interface DrummerCard {
	id: string;
	title: string;
	image: string;
	youtubeId: string;
	startTime?: number;
}

function decodeEntities(str: string) {
	return str.replace(/&#(\d+);/g, (_, code) => String.fromCharCode(Number(code)))
		.replace(/&amp;/g, '&')
		.replace(/&lt;/g, '<')
		.replace(/&gt;/g, '>')
		.replace(/&quot;/g, '"')
		.replace(/&#039;/g, "'");
}

const WP_API = 'https://martybeller.mysites.io/wp-json/wp/v2';

async function resolveTrack(mediaId: number) {
	const res = await fetch(`${WP_API}/media/${mediaId}`);
	const media = await res.json();

	return {
		title: decodeEntities(media.title?.rendered || ''),
		url: media.source_url || '',
	};
}

const [workRes, videosRes] = await Promise.all([
	fetch(`${WP_API}/work?per_page=100&_embed&orderby=date&order=desc&_=${Date.now()}`),
	fetch(`${WP_API}/videos?per_page=100&orderby=date&order=desc&_=${Date.now()}`),
]);

const allWorkPosts = await workRes.json();
const allVideoPosts = await videosRes.json();

const composerCards: ComposerCard[] = await Promise.all(
	allWorkPosts.map(async (post: any) => {
		const media = post._embedded?.['wp:featuredmedia']?.[0];
		const sizes = media?.media_details?.sizes;
		const image = sizes?.full?.source_url || '';

		const trackEntries = (post.acf?.each_track || []).filter((track: any) => track?.audio_file);
		const tracks = await Promise.all(trackEntries.map((track: any) => resolveTrack(track.audio_file)));

		return {
			id: String(post.id),
			title: decodeEntities(post.title?.rendered || ''),
			image,
			owner: post.acf?.owner || '',
			tracks,
		};
	})
);

const drummerCards: DrummerCard[] = await Promise.all(allVideoPosts
	.filter((post: any) => post.acf?.youtube_video_id)
	.map(async (post: any) => {
		const ytId = post.acf?.youtube_video_id || '';
		let image = `https://img.youtube.com/vi/${ytId}/hqdefault.jpg`;
		if (post.acf?.placeholder_key_image) {
			const res = await fetch(`${WP_API}/media/${post.acf.placeholder_key_image}`);
			const media = await res.json();
			const large = media?.media_details?.sizes?.large?.source_url;
			if (large) image = large;
		}
		return {
			id: `vid-${post.id}`,
			title: decodeEntities(post.title?.rendered || ''),
			image,
			youtubeId: ytId,
			startTime: post.acf?.start_time ? Number(post.acf.start_time) : undefined,
		};
	}));
---

<Layout title="Marty Beller | Film & TV Scoring Credits | American Rust, Tiger King" description="Explore the music portfolio of Marty Beller. Featuring original scores for American Rust, In Treatment, Tiger King, and more. Expert composition for Film, TV, and Media.">
	<section class="px-6 pb-12 pt-5 sm:pt-24 relative z-10">
		<div class="mx-auto w-full max-w-max">
			<h1 class="font-headline font-light leading-[0.83] tracking-tight text-6xl sm:text-7xl lg:text-8xl">
				MUSIC.
			</h1>
		</div>
	</section>

	<section class="px-12 pb-12 relative z-10">
		<div class="mx-auto flex max-w-max flex-col gap-8 relative z-10">
			<div class="flex items-center gap-8">
				<button
					type="button"
					data-tab-trigger="composer"
					data-active-classes="text-white"
					data-inactive-classes="text-white/50"
					class="pb-3 font-headline text-[40px] font-normal leading-[1.2] text-white cursor-pointer transition hover:text-white"
					aria-selected="true"
				>
					Composer
				</button>
				<button
					type="button"
					data-tab-trigger="drummer"
					data-active-classes="text-white"
					data-inactive-classes="border-transparent text-white/50"
					class="pb-3 font-headline text-[40px] cursor-pointer font-normal leading-[1.2] text-white/50 transition hover:text-white"
					aria-selected="false"
				>
					Drummer
				</button>
			</div>

			<div data-tab-panel="composer" class="relative z-10 flex flex-col gap-8">
				<div class="flex flex-wrap gap-x-4 gap-y-8">
					{composerCards.map((card) => (
						<button
							type="button"
							data-open-work-modal={card.id}
							class="group flex min-w-[200px] basis-[calc((100%-80px)/6)] cursor-pointer flex-col gap-4 text-left"
						>
								<div class="aspect-7/10 w-full overflow-hidden rounded-lg bg-neutral-800">
									{card.image && (
									<img
										src={card.image}
										alt={card.title}
										class="h-full w-full object-cover transition duration-300 group-hover:scale-105" loading="lazy" decoding="async"
									/>
								)}
							</div>
							<div class="flex flex-col gap-1">
								<h2 class="font-headline text-2xl font-semibold text-neutral-100">{card.title}</h2>
							</div>
						</button>
					))}
				</div>

				{composerCards.map((card) => (
					<WorkModal
						id={card.id}
						title={card.title}
						owner={card.owner}
						image={card.image}
						tracks={card.tracks}
					/>
				))}
			</div>

			<div data-tab-panel="drummer" class="hidden relative z-10 flex-col gap-8">
				<div class="flex flex-wrap gap-x-4 gap-y-8">
					{drummerCards.map((card) => (
						<button
							type="button"
							data-open-modal={card.id}
							class="group flex min-w-[200px] basis-[calc((100%-80px)/6)] cursor-pointer flex-col gap-4 text-left"
						>
							<div class="aspect-7/10 w-full overflow-hidden rounded-lg bg-neutral-800">
								<img
									src={card.image}
									alt={card.title}
									class="h-full w-full object-cover transition duration-300 group-hover:scale-105" loading="lazy" decoding="async"
								/>
							</div>
							<div class="flex flex-col gap-1">
								<h2 class="font-headline text-2xl font-semibold text-neutral-100">{card.title}</h2>
							</div>
						</button>
					))}
				</div>

				{drummerCards.map((card) => (
					<VideoModal
						id={card.id}
						title={card.title}
						youtubeId={card.youtubeId}
						startTime={card.startTime}
					/>
				))}
			</div>
		</div>
	</section>
</Layout>

<script is:inline>
	const composerOpenButtons = document.querySelectorAll('[data-open-work-modal]');
	composerOpenButtons.forEach((button) => {
		button.addEventListener('click', () => {
			const id = button.getAttribute('data-open-work-modal');
			document.getElementById(`modal-${id}`)?.showModal();
		});
	});

	const triggers = Array.from(document.querySelectorAll('[data-tab-trigger]'));
	const panels = Array.from(document.querySelectorAll('[data-tab-panel]'));
	const params = new URLSearchParams(window.location.search);
	const requestedTab = params.get('tab');
	const initialTab = requestedTab === 'drummer' ? 'drummer' : 'composer';

	function setTab(nextTab) {
		triggers.forEach((trigger) => {
			const isActive = trigger.getAttribute('data-tab-trigger') === nextTab;
			const activeClasses = (trigger.getAttribute('data-active-classes') || '').split(' ').filter(Boolean);
			const inactiveClasses = (trigger.getAttribute('data-inactive-classes') || '').split(' ').filter(Boolean);

			trigger.setAttribute('aria-selected', String(isActive));
			trigger.classList.remove(...activeClasses, ...inactiveClasses);
			trigger.classList.add(...(isActive ? activeClasses : inactiveClasses));
		});

		panels.forEach((panel) => {
			const isActive = panel.getAttribute('data-tab-panel') === nextTab;
			panel.classList.toggle('hidden', !isActive);
			panel.classList.toggle('flex', isActive);
		});

		const url = new URL(window.location.href);
		if (nextTab === 'composer') {
			url.searchParams.delete('tab');
		} else {
			url.searchParams.set('tab', nextTab);
		}
		window.history.replaceState({}, '', url);
	}

	triggers.forEach((trigger) => {
		trigger.addEventListener('click', () => {
			setTab(trigger.getAttribute('data-tab-trigger') || 'composer');
		});
	});

	setTab(initialTab); 
</script>