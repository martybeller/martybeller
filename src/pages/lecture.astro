---
import Layout from '../layouts/Layout.astro';

interface RundownItemApi {
	id: number;
	title?: {
		rendered?: string;
	};
	acf?: {
		'sub-title'?: string;
		description?: string;
	};
}

interface RundownItem {
	id: number;
	title: string;
	subtitle: string;
	description: string;
}

const WP_API = 'https://martybeller.mysites.io/wp-json/wp/v2';
const basePath = Astro.site ? new URL(Astro.site.href).pathname.replace(/\/?$/, '/') : '/';
const withBase = (path: string) => `${basePath}${path.replace(/^\//, '')}`;

const decodeEntities = (value: string) =>
	value
		.replace(/&#(\d+);/g, (_, code) => String.fromCharCode(Number(code)))
		.replace(/&#x([\da-fA-F]+);/g, (_, code) => String.fromCharCode(parseInt(code, 16)))
		.replace(/&amp;/g, '&')
		.replace(/&lt;/g, '<')
		.replace(/&gt;/g, '>')
		.replace(/&quot;/g, '"')
		.replace(/&#039;/g, "'");

let rundownItems: RundownItem[] = [];

try {
	const response = await fetch(`${WP_API}/rundown-item?per_page=100&_=${Date.now()}`);
	if (response.ok) {
		const data = (await response.json()) as RundownItemApi[];
		rundownItems = data
			.map((item) => ({
				id: item.id,
				title: decodeEntities(item.title?.rendered?.trim() ?? ''),
				subtitle: decodeEntities(item.acf?.['sub-title']?.trim() ?? ''),
				description: decodeEntities(item.acf?.description?.trim() ?? ''),
			}))
			.filter((item) => item.title.length > 0);
	}
} catch {
	rundownItems = [];
}

const rundownMidpoint = Math.ceil(rundownItems.length / 2);
const leftRundownItems = rundownItems.slice(0, rundownMidpoint);
const rightRundownItems = rundownItems.slice(rundownMidpoint);
---

<Layout title="Marty Beller Guest Artist Lecture | Music Career & Composing Insights" description="Join Grammy-winning composer and They Might Be Giants drummer Marty Beller for an interactive lecture on touring, scoring for Film/TV, and building a professional music career.">
	<!-- Hero -->
	<section class="relative flex min-h-[58vh] flex-col justify-end md:justify-start overflow-hidden bg-[position:80%_top] xl:bg-center bg-cover px-6 pb-12 pt-5 sm:pb-16 sm:pt-24 lg:pb-28" style={`background-image: url('${withBase('/mb-lecture-hero-bg-v1.webp')}')`}>
		<div class="w-full max-w-max mx-auto">
			<h1 class="font-headline font-light leading-[0.83] tracking-tight text-6xl sm:text-7xl lg:text-8xl">
				GUEST ARTIST<br />LECTURE.
			</h1>
		</div>
	</section>

	<!-- Intro -->
	<section class="relative z-10 px-6 pt-4 sm:pt-16 lg:pt-24">
		<div class="mx-auto flex w-full max-w-max flex-col gap-10 lg:flex-row lg:gap-12">
			<!-- Left column -->
			<div class="flex w-full flex-col lg:w-1/2">
				<h2 class="font-body text-3xl font-light leading-[1.1] text-white sm:text-4xl lg:text-5xl"><span class="font-semibold">Twists, Turns and Breakthroughs:</span><br>Inside the Work of a Recording, Touring &amp; Composing Career</h2>
				<p class="font-body text-xl font-normal leading-tight text-white sm:text-2xl lg:text-[32px] mt-8">Marty Beller, Grammy Award&ndash;winning composer and longtime drummer for the iconic alt-rock band <span class="whitespace-nowrap">They Might Be Giants</span>, brings students inside the real world of a professional musician whose career moves seamlessly between recording, touring, and scoring for the screen&mdash;on stage, in the studio, and in the creative spaces where projects come to life.</p>
			</div>
			<!-- Right column -->
			<div class="flex w-full flex-col gap-6 sm:gap-8 lg:w-1/2">
				<p class="font-body text-xl font-normal leading-tight text-white sm:text-2xl lg:text-[32px] text-pretty">This 60-90 minute interactive lecture is designed for university music students and is ideal for lecture series, visiting artist programs, and music school forums.</p>
				<p class="font-body text-lg font-normal leading-snug text-white sm:text-xl lg:text-2xl text-pretty">Drawing on decades of experience drumming with <span class="whitespace-nowrap">They Might Be Giants</span>, and scoring for Film/TV, Marty brings students into the recording studio, onto the stage, and into vibrant creative meetings, immersing them in a whirlwind of twists, turns, and breakthroughs. Do you want this all-consuming, exhilarating lifestyle more than anything else in the world?! Yes, you do!</p>
				<p class="font-body text-lg font-normal leading-snug text-white sm:text-xl lg:text-2xl text-pretty">Students leave with a clear understanding of what a working music career looks like &mdash; and the importance of finding your voice, showing up hungry and grabbing every opportunity.</p>
			</div>
		</div>
	</section>

	<!-- Testimonial -->
	<section class="relative z-10 px-6 pt-12 sm:pt-16 lg:pt-24">
		<div class="mx-auto w-full max-w-max overflow-hidden rounded-xl bg-[#3C3DA6] p-5 sm:p-6">
			<blockquote class="flex flex-col lg:flex-row gap-4 lg:gap-6">
				<p class="relative max-w-216.75 pl-[0.7em] font-accent text-xl font-medium leading-snug text-white sm:text-2xl lg:text-balance">
					<span aria-hidden="true" class="absolute top-0 left-1.5">&ldquo;</span>
					Marty showed our students that a career in music can take many shapes and inspired them to pursue their own creative vision.&rdquo;
				</p>
				<div class="flex flex-col items-start gap-4 sm:flex-row sm:items-center sm:gap-6">
					<img
						src={withBase('/colton-dodd.webp')}
						alt="Colton Dodd"
						class="h-18 w-18 shrink-0 overflow-hidden rounded-full object-cover"
					/>
					<div class="">
						<p class="font-accent text-base font-bold leading-tight text-white">Colton Dodd</p>
						<p class="font-accent text-base font-medium leading-tight text-white text-balance">Professor at Peabody Institute at Johns Hopkins University</p>
					</div>
				</div>
			</blockquote>
		</div>
	</section>

	{rundownItems.length > 0 && (
		<section class="relative z-10 px-6 pt-12 sm:pt-16 lg:pt-20">
			<div class="mx-auto flex w-full max-w-max flex-col gap-6">
				<h2 class="font-accent text-4xl font-medium leading-snug text-white sm:text-5xl">The Rundown</h2>
				<div class="grid grid-cols-1 gap-8 md:gap-10 lg:grid-cols-2 lg:gap-12">
					<div class="flex flex-col gap-8 lg:gap-10">
						{leftRundownItems.map((item, index) => (
							<div class="flex flex-col gap-8 lg:gap-10">
								<div class="flex gap-5">
									<span class="font-headline text-3xl font-light leading-none tracking-[2px] text-neutral-500 sm:text-[40px]">{index + 1}</span>
									<div class="flex flex-1 flex-col gap-2">
										<h3 class="font-headline text-2xl leading-none font-medium text-white sm:text-[32px]">{item.title}</h3>
										{item.subtitle.length > 0 && <p class="font-accent text-xl font-bold leading-snug text-white sm:text-2xl text-pretty">{item.subtitle}</p>}
										{item.description.length > 0 && <p class="font-body text-lg font-normal leading-snug text-neutral-300 sm:text-xl lg:text-2xl text-pretty">{item.description}</p>}
									</div>
								</div>
								{index < leftRundownItems.length - 1 && <hr class="border-0 border-t border-dashed border-white" />}
							</div>
						))}
					</div>
					<div class="flex flex-col gap-8 lg:gap-10">
						{rightRundownItems.map((item, index) => (
							<div class="flex flex-col gap-8 lg:gap-10">
								<div class="flex gap-5">
									<span class="font-headline text-3xl font-light leading-none tracking-[2px] text-neutral-500 sm:text-[40px]">{rundownMidpoint + index + 1}</span>
									<div class="flex flex-1 flex-col gap-2">
										<h3 class="font-headline text-2xl leading-none font-medium text-white sm:text-[32px]">{item.title}</h3>
										{item.subtitle.length > 0 && <p class="font-accent text-xl font-bold leading-snug text-white sm:text-2xl text-pretty">{item.subtitle}</p>}
										{item.description.length > 0 && <p class="font-body text-lg font-normal leading-snug text-neutral-300 sm:text-xl lg:text-2xl text-pretty">{item.description}</p>}
									</div>
								</div>
								{index < rightRundownItems.length - 1 && <hr class="border-0 border-t border-dashed border-white" />}
							</div>
						))}
					</div>
				</div>
			</div>
		</section>
	)}

	<!-- Beyond the Lecture -->
	<section class="relative z-10 px-6 pb-16 pt-12 sm:pb-20 sm:pt-16 lg:pb-24 lg:pt-24">
		<div class="mx-auto flex max-w-max flex-col gap-6 sm:gap-8">
			<h2 class="font-accent text-4xl font-medium leading-snug text-white sm:text-5xl">Beyond the Lecture</h2>
			<p class="font-body text-xl font-normal leading-tight text-neutral-300 sm:text-2xl lg:text-[32px]">Marty would be genuinely excited to extend his time on campus and has designed his lecture to be flexible and adaptive. Here are some examples: Extended/Expanded Lectures, One-on-One Coaching/Mentoring, and Ensemble/Studio visits.</p>
		</div>
	</section>
</Layout>
