---
import WorkModal from './WorkModal.astro';
import VideoModal from './VideoModal.astro';
import 'swiper/css';

interface Track {
	title: string;
	url: string;
}

interface Card {
	id: string;
	title: string;
	image?: string;
	owner?: string;
	tracks?: Track[];
	youtubeId?: string;
	link?: string;
}

interface Props {
	sectionTitle: string;
	seeAllLink?: string;
	cards: Card[];
	peekCards?: boolean;
}

const { sectionTitle, seeAllLink, cards, peekCards = false } = Astro.props;
const basePath = Astro.site ? new URL(Astro.site.href).pathname.replace(/\/?$/, '/') : '/';
const withBase = (path: string) => `${basePath}${path.replace(/^\//, '')}`;
const resolvedSeeAllLink = seeAllLink ? withBase(seeAllLink) : undefined;
---

<div class="flex w-full min-w-0 flex-col gap-6 sm:gap-8 max-w-max mx-auto mt-10 z-10">
	<!-- Title row -->
	<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
		<h2 class="font-headline text-3xl font-normal leading-[1.1] sm:text-[40px] sm:leading-[1.2]">{sectionTitle}</h2>
		{resolvedSeeAllLink && (
			<a href={resolvedSeeAllLink} class="font-headline text-base font-semibold text-white transition hover:text-white/80">
				See All
			</a>
		)}
	</div>

	<!-- Cards row - Swiper carousel -->
	<div class="swiper work-swiper w-full min-w-0" data-work-swiper>
		<div class="swiper-wrapper">
			{cards.map((card) => (
				<div class="swiper-slide">
					<button
						type="button"
						data-open-modal={card.id}
						class="group flex w-full cursor-pointer flex-col gap-4 text-left"
					>
						<div class="aspect-7/10 w-full overflow-hidden rounded-lg bg-neutral-800 sm:rounded-xl">
							{card.image && (
								<img
									src={card.image}
									alt={card.title}
									class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
								/>
							)}
						</div>
						<div class="flex flex-col">
							<h3 class="font-headline text-xl font-semibold text-neutral-100 sm:text-2xl">{card.title}</h3>
						</div>
					</button>
				</div>
			))}
		</div>
	</div>

	<!-- Modals -->
	{cards.map((card) =>
		card.youtubeId ? (
			<VideoModal
				id={card.id}
				title={card.title}
				youtubeId={card.youtubeId}
			/>
		) : (
			<WorkModal
				id={card.id}
				title={card.title}
				owner={card.owner || ''}
				image={card.image || ''}
				tracks={card.tracks || []}
			/>
		)
	)}
</div>

<script>
	import Swiper from 'swiper';

	document.querySelectorAll('[data-open-modal]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const id = btn.getAttribute('data-open-modal');
			document.getElementById(`modal-${id}`)?.showModal();
		});
	});

	document.querySelectorAll<HTMLElement>('[data-work-swiper]').forEach((el) => {
		new Swiper(el, {
			slidesPerView: 1.5,
			spaceBetween: 12,
			grabCursor: true,
			breakpoints: {
				525: {
					slidesPerView: 2.5,
					spaceBetween: 12,
				},
				768: {
					slidesPerView: 3.5,
					spaceBetween: 12,
				},
				1344: {
					slidesPerView: 6,
					spaceBetween: 12,
				},
			},
		});
	});
</script>

<style is:global>
	.work-swiper {
		overflow: hidden;
		position: relative;
	}
</style>
