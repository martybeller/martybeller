---
import WorkModal from './WorkModal.astro';
import VideoModal from './VideoModal.astro';

interface Track {
	title: string;
	url: string;
}

interface Card {
	id: string;
	title: string;
	image?: string;
	owner?: string;
	tracks?: Track[];
	youtubeId?: string;
	link?: string;
}

interface Props {
	sectionTitle: string;
	seeAllLink?: string;
	cards: Card[];
	peekCards?: boolean;
}

const { sectionTitle, seeAllLink, cards, peekCards = false } = Astro.props;
const basePath = Astro.site ? new URL(Astro.site.href).pathname.replace(/\/?$/, '/') : '/';
const withBase = (path: string) => `${basePath}${path.replace(/^\//, '')}`;
const resolvedSeeAllLink = seeAllLink ? withBase(seeAllLink) : undefined;
---

<div class="flex flex-col gap-6 sm:gap-8 max-w-max mx-auto mt-20 z-10">
	<!-- Title row -->
	<div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
		<h2 class="font-headline text-3xl font-normal leading-[1.1] sm:text-[40px] sm:leading-[1.2]">{sectionTitle}</h2>
		{resolvedSeeAllLink && (
			<a href={resolvedSeeAllLink} class="font-headline text-base font-semibold text-white transition hover:text-white/80">
				See All
			</a>
		)}
	</div>

	<!-- Cards row - horizontal scroll -->
	<div class:list={["flex gap-3 overflow-x-auto pb-2 scrollbar-hide sm:gap-4", peekCards && 'work-cards-row--peek']}>
		{cards.map((card) => (
			<button
				type="button"
				data-open-modal={card.id}
				class:list={[
					'group flex shrink-0 cursor-pointer flex-col gap-4 text-left',
					peekCards
						? 'work-card--peek'
						: 'w-[calc((100%-64px)/6)] min-w-50',
				]}
			>
				<div class="aspect-7/10 w-full overflow-hidden rounded-lg bg-neutral-800 sm:rounded-xl">
					{card.image && (
						<img
							src={card.image}
							alt={card.title}
							class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
						/>
					)}
				</div>
				<div class="flex flex-col">
					<h3 class="font-headline text-xl font-semibold text-neutral-100 sm:text-2xl">{card.title}</h3>
				</div>
			</button>
		))}
	</div>

	<!-- Modals -->
	{cards.map((card) =>
		card.youtubeId ? (
			<VideoModal
				id={card.id}
				title={card.title}
				youtubeId={card.youtubeId}
			/>
		) : (
			<WorkModal
				id={card.id}
				title={card.title}
				owner={card.owner || ''}
				image={card.image || ''}
				tracks={card.tracks || []}
			/>
		)
	)}
</div>

<script is:inline>
	document.querySelectorAll('[data-open-modal]').forEach((btn) => {
		btn.addEventListener('click', () => {
			const id = btn.getAttribute('data-open-modal');
			document.getElementById(`modal-${id}`)?.showModal();
		});
	});
</script>

<style>
	.work-cards-row--peek {
		--peek-card-count: 2.3;
		--peek-gap-count: 2;
	}

	.work-card--peek {
		width: calc((100% - (var(--peek-gap-count) * 1rem)) / var(--peek-card-count));
		min-width: calc((100% - (var(--peek-gap-count) * 1rem)) / var(--peek-card-count));
	}

	@media (min-width: 640px) {
		.work-cards-row--peek {
			--peek-card-count: 3.3;
			--peek-gap-count: 2;
		}
	}

	@media (min-width: 900px) {
		.work-cards-row--peek {
			--peek-card-count: 4.3;
			--peek-gap-count: 3;
		}
	}

	@media (min-width: 1180px) {
		.work-cards-row--peek {
			--peek-card-count: 5.3;
			--peek-gap-count: 4;
		}
	}

	@media (min-width: 1344px) {
		.work-cards-row--peek {
			--peek-card-count: 6;
			--peek-gap-count: 5;
		}
	}
</style>
