---
interface Props {
	backgroundImage?: string;
	photoCredit?: string;
}

const { backgroundImage, photoCredit = 'Photo: Jon Uleis' } = Astro.props;
const basePath = Astro.site ? new URL(Astro.site.href).pathname.replace(/\/?$/, '/') : '/';
const withBase = (path: string) => `${basePath}${path.replace(/^\//, '')}`;
const heroBackgroundImage = backgroundImage
	? withBase(backgroundImage)
	: withBase('/mb-banner-bg-v1.webp');
---

<section class="relative flex min-h-[72vh] flex-col justify-between overflow-hidden bg-cover bg-bottom px-5 pb-12 pt-0 sm:min-h-[76vh] sm:px-6 sm:pb-16 lg:min-h-[80vh] lg:px-12 lg:pb-28" style={`background-image: url('${heroBackgroundImage}')`}>
	<!-- Gradient overlay -->
	<div class="pointer-events-none absolute inset-x-0 bottom-0 h-80 bg-linear-to-t from-black to-transparent"></div>

	<div class="relative z-10 mx-auto flex w-full max-w-max flex-1 flex-col justify-between">
		<!-- Large headline -->
		<h1 class="mt-6 font-headline text-6xl font-light leading-[0.83] tracking-tight sm:text-7xl md:text-8xl lg:text-[120px]">
			DRUMMER<br />COMPOSER
		</h1>

		<!-- Bottom info bar -->
		<div class="flex flex-col items-start gap-4 sm:gap-5 lg:flex-row lg:items-end lg:justify-between lg:gap-8">
			<p class="max-w-166 font-body text-2xl font-normal leading-tight sm:text-2xl lg:text-3xl">
				Grammy award winner Drummer for They Might Be Giants Composer for Film &amp; TV
			</p>
			{photoCredit && (
				<span class="font-body text-sm text-white sm:text-base lg:shrink-0">{photoCredit}</span>
			)}
		</div>
	</div>
</section>
