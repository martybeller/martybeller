---
interface Props {
	backgroundImage?: string;
}

const { backgroundImage } = Astro.props;
const basePath = Astro.site ? new URL(Astro.site.href).pathname.replace(/\/?$/, '/') : '/';
const withBase = (path: string) => `${basePath}${path.replace(/^\//, '')}`;
const lectureHref = withBase('/lecture/');
const lectureBackgroundImage = backgroundImage ? withBase(backgroundImage) : undefined;
---

<section id="lecture" class="mx-auto max-w-max px-5 sm:px-6 lg:px-12">
	<a href={lectureHref} class="group relative block overflow-hidden rounded-xl bg-white bg-cover bg-center p-5 sm:p-6 lg:p-8" style={lectureBackgroundImage ? `background-image: url('${lectureBackgroundImage}')` : ''}>
		<div class="relative z-10 flex min-h-[360px] flex-col justify-between gap-10 sm:min-h-[420px] sm:gap-14 lg:min-h-[520px]">
			<h2 class="font-headline text-5xl font-normal leading-[0.95] text-white sm:text-6xl lg:text-[72px]">
				Guest Artist<br />Lecture
			</h2>
			<p class="max-w-[600px] font-body text-xl font-normal leading-tight text-white sm:text-2xl lg:text-[32px]">
				Twists, Turns and Breakthroughs: Inside the Work of Recording, Touring & Composing
			</p>
		</div>
	</a>
</section>
