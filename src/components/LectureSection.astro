---
interface Props {
	backgroundImage?: string;
}

const { backgroundImage } = Astro.props;
const basePath = Astro.site ? new URL(Astro.site.href).pathname.replace(/\/?$/, '/') : '/';
const withBase = (path: string) => `${basePath}${path.replace(/^\//, '')}`;
const lectureHref = withBase('/lecture/');
const lectureBackgroundImage = backgroundImage ? withBase(backgroundImage) : undefined;
---

<section id="lecture" class="px-6 relative z-10 mt-36">
	<a href={lectureHref} class="group max-w-max mx-auto w-full min-h-80 relative block overflow-hidden rounded-xl p-5 sm:p-6 lg:p-8">
		<!-- Background layer for zoom effect -->
		<div class="absolute inset-0 bg-cover [background-position:center_15%] transition-transform duration-500 ease-out group-hover:scale-105 group-focus:scale-105" style={lectureBackgroundImage ? `background-image: url('${lectureBackgroundImage}')` : ''}></div>
		<div class="relative z-10 flex flex-col justify-between gap-10 sm:gap-14">
			<h2 class="font-headline text-5xl font-normal leading-[0.95] text-white sm:text-6xl lg:text-[72px]">
				Guest Artist<br />Lecture
			</h2>
			<div class="max-w-7/12">
				<p class="font-body font-semibold leading-tight text-white text-xl sm:text-2xl lg:text-3xl">
					Twists, Turns and Breakthroughs:
				</p>
				<p class="font-body text-xl font-normal leading-tight text-white sm:text-2xl lg:text-3xl">
					Inside the Work of Recording, Touring &amp; Composing
				</p>
			</div>
		</div>
	</a>
</section>
