---
interface Props {
	backgroundImage?: string;
}

const { backgroundImage } = Astro.props;
---

<section id="lecture" class="mx-auto max-w-[var(--container-max)] px-12">
	<a href="/lecture" class="group relative block overflow-hidden rounded-xl bg-white bg-cover bg-center p-8" style={backgroundImage ? `background-image: url(${backgroundImage})` : ''}>
		<div class="relative z-10 flex h-full flex-col justify-between">
			<h2 class="font-headline text-[72px] font-normal leading-[1] text-white">
				Guest Artist<br />Lecture
			</h2>
			<p class="max-w-[600px] font-body text-[32px] font-normal leading-tight text-white">
				Twists, Turns and Breakthroughs: Inside the Work of Recording, Touring & Composing
			</p>
		</div>
	</a>
</section>
