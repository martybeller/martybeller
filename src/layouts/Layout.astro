---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Marty Beller',
	description = 'Hear work from musician Marty Beller, and his newest projects.',
} = Astro.props;
const basePath = Astro.site ? new URL(Astro.site.href).pathname.replace(/\/?$/, '/') : '/';
const withBase = (path: string) => `${basePath}${path.replace(/^\//, '')}`;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<script is:inline>
			const windowWithDataLayer = /** @type {Window & { dataLayer: Array<Record<string, unknown>> }} */ (window);
			windowWithDataLayer.dataLayer = windowWithDataLayer.dataLayer || [];
			windowWithDataLayer.dataLayer.push({
				'gtm.start': Date.now(),
				event: 'gtm.js',
			});

			const firstScript = document.getElementsByTagName('script')[0];
			const gtmScript = /** @type {HTMLScriptElement} */ (document.createElement('script'));
			gtmScript.async = true;
			gtmScript.src = 'https://www.googletagmanager.com/gtm.js?id=GTM-KMBVLQ7B';
			firstScript?.parentNode?.insertBefore(gtmScript, firstScript);
		</script>
		<link rel="icon" type="image/svg+xml" href={withBase('/favicon.svg')} />
		<link rel="icon" href={withBase('/favicon.ico')} />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,100..900;1,100..900&family=Manrope:wght@200..800&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title}</title>
	</head>
	<body class="relative bg-black text-white font-body antialiased overflow-x-hidden">
		<noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-KMBVLQ7B"
		height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>
		<!-- Decorative blurred orbs -->
		<div class="pointer-events-none fixed bottom-[-20%] left-[-50%] z-0 h-[105vw] w-[105vw] rounded-full bg-primary blur-[1000px]" aria-hidden="true">
			<div class="absolute inset-0 rounded-full bg-noise opacity-25 mix-blend-multiply"></div>
		</div>
		<div class="pointer-events-none fixed bottom-[-50%] right-[-30%] z-0 h-[105vw] w-[105vw] rounded-full bg-primary blur-[1000px]" aria-hidden="true">
			<div class="absolute inset-0 rounded-full bg-noise opacity-25 mix-blend-multiply"></div>
		</div>

		<div class="relative z-10">
			<Header />
			<main>
				<slot />
			</main>
			<Footer />
		</div>
	</body>
</html>
